APP_NAME=Enterprise Knowledge Copilot
APP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

UPLOAD_DIR=data/uploads
DOCUMENT_REGISTRY_PATH=data/document_registry.json
UPLOAD_DUPLICATE_POLICY=replace

CONVERSATION_DIR=data/conversations
AUTH_USERS_PATH=data/auth_users.json
AUTH_SESSIONS_PATH=data/auth_sessions.json
AUTH_TOKEN_SECRET=local-dev-auth-secret
AUTH_TOKEN_EXPIRE_SECONDS=604800

MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=enterprise_rag_docs_ollama
MILVUS_DIM=3584

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=qwen2.5:7b

EMBED_PROVIDER=ollama
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

CHUNK_SIZE=700
CHUNK_OVERLAP=120
TOP_K=5
VECTOR_SEARCH_LIMIT=20
LEXICAL_SEARCH_LIMIT=2000
HYBRID_RRF_K=60
QUERY_REWRITE_HISTORY_TURNS=3
ENABLE_QUERY_REWRITE=true

RERANK_TOP_K=5
MIN_RERANK_SCORE=0.28
MIN_QUERY_TOKEN_MATCHES=1
MAX_SEMANTIC_DISTANCE=1.35
MIN_GROUNDED_DOCS=1

CACHE_EXPIRE_SECONDS=3600
HISTORY_LIMIT=10
